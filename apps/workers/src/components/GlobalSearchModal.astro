---
import { DEMO_API_URL } from '../data/configurator.ts';
---

<search-modal-snippet
  id="globalSearchModal"
  data-global-search-modal
  data-site-theme-sync
  api-url={DEMO_API_URL}
  show-url="true"
  placeholder="Search documentation..."
  max-results="8"
  show-date="true"
  see-more="https://developers.cloudflare.com/search/?q="
></search-modal-snippet>
