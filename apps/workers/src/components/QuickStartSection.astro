---
import { QUICK_START_EXAMPLES } from '../data/examples.ts';
import SectionHeader from './SectionHeader.astro';
---

<section class="section" id="quick-start">
  <SectionHeader title="Quick Start Guide" description="Add search and chat to your website in minutes." />

  <div class="code-block" data-quickstart>
    <div class="quickstart-tabs">
      {
        QUICK_START_EXAMPLES.map((example, index) => (
          <button
            class={index === 0 ? 'quickstart-tab active' : 'quickstart-tab'}
            data-quickstart-tab={example.id}
            type="button"
          >
            {example.id === 'html' && (
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M1.5 0h21l-1.91 21.563L11.977 24l-8.564-2.438L1.5 0zm7.031 9.75l-.232-2.718 10.059.003.23-2.622L5.412 4.41l.698 8.01h9.126l-.326 3.426-2.91.804-2.955-.81-.188-2.11H6.248l.33 4.171L12 19.351l5.379-1.443.744-8.157H8.531z" />
              </svg>
            )}
            {example.id === 'react' && (
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M14.23 12.004a2.236 2.236 0 0 1-2.235 2.236 2.236 2.236 0 0 1-2.236-2.236 2.236 2.236 0 0 1 2.235-2.236 2.236 2.236 0 0 1 2.236 2.236zm2.648-10.69c-1.346 0-3.107.96-4.888 2.622-1.78-1.653-3.542-2.602-4.887-2.602-.41 0-.783.093-1.106.278-1.375.793-1.683 3.264-.973 6.365C1.98 8.917 0 10.42 0 12.004c0 1.59 1.99 3.097 5.043 4.03-.704 3.113-.39 5.588.988 6.38.32.187.69.275 1.102.275 1.345 0 3.107-.96 4.888-2.624 1.78 1.654 3.542 2.603 4.887 2.603.41 0 .783-.09 1.106-.275 1.374-.792 1.683-3.263.973-6.365C22.02 15.096 24 13.59 24 12.004c0-1.59-1.99-3.097-5.043-4.032.704-3.11.39-5.587-.988-6.38-.318-.184-.688-.277-1.092-.278zm-.005 1.09v.006c.225 0 .406.044.558.127.666.382.955 1.835.73 3.704-.054.46-.142.945-.25 1.44-.96-.236-2.006-.417-3.107-.534-.66-.905-1.345-1.727-2.035-2.447 1.592-1.48 3.087-2.292 4.105-2.295zm-9.77.02c1.012 0 2.514.808 4.11 2.28-.686.72-1.37 1.537-2.02 2.442-1.107.117-2.154.298-3.113.538-.112-.49-.195-.964-.254-1.42-.23-1.868.054-3.32.714-3.707.19-.09.4-.127.563-.132zm4.882 3.05c.455.468.91.992 1.36 1.564-.44-.02-.89-.034-1.345-.034-.46 0-.915.01-1.36.034.44-.572.895-1.096 1.345-1.565zM12 8.1c.74 0 1.477.034 2.202.093.406.582.802 1.203 1.183 1.86.372.64.71 1.29 1.018 1.946-.308.655-.646 1.31-1.013 1.95-.38.66-.773 1.288-1.18 1.87-.728.063-1.466.098-2.21.098-.74 0-1.477-.035-2.202-.093-.406-.582-.802-1.204-1.183-1.86-.372-.64-.71-1.29-1.018-1.946.303-.657.646-1.313 1.013-1.954.38-.66.773-1.286 1.18-1.868.728-.064 1.466-.098 2.21-.098zm-3.635.254c-.24.377-.48.763-.704 1.16-.225.39-.435.782-.635 1.174-.265-.656-.49-1.31-.676-1.947.64-.15 1.315-.283 2.015-.386zm7.26 0c.695.103 1.365.23 2.006.387-.18.632-.405 1.282-.66 1.933-.2-.39-.41-.783-.64-1.174-.225-.392-.465-.774-.705-1.146zm3.063.675c.484.15.944.317 1.375.498 1.732.74 2.852 1.708 2.852 2.476-.005.768-1.125 1.74-2.857 2.475-.42.18-.88.342-1.355.493-.28-.958-.646-1.956-1.1-2.98.45-1.017.81-2.01 1.085-2.964zm-13.395.004c.278.96.645 1.957 1.1 2.98-.45 1.017-.812 2.01-1.085 2.964-.48-.15-.944-.313-1.38-.498C1.125 13.744 0 12.772 0 12.004c0-.768 1.125-1.74 2.857-2.475.425-.18.89-.342 1.355-.493zM8.37 15.648c.24.377.48.763.704 1.16.225.39.435.782.635 1.174-.265-.656-.49-1.31-.676-1.947-.64-.15-1.315-.283-2.015-.386.18.632.405 1.282.66 1.933.2-.39.41-.783.64-1.174.225-.392.465-.774.705-1.146zm7.26 0c-.24.372-.48.754-.704 1.146-.225.39-.435.783-.635 1.174.265-.651.49-1.301.676-1.933.64.103 1.315.236 2.015.386-.18.637-.405 1.291-.66 1.947-.2-.392-.41-.784-.64-1.174-.225-.397-.465-.783-.705-1.16zm-3.625 2.878c-.455-.468-.91-.992-1.36-1.564.445.024.9.034 1.36.034.455 0 .905-.01 1.345-.034-.45.572-.905 1.096-1.345 1.564zm-4.877 3.07c-.225 0-.406-.043-.558-.126-.666-.382-.955-1.836-.73-3.704.054-.46.142-.945.25-1.44.96.236 2.006.417 3.107.534.66.905 1.345 1.727 2.035 2.447-1.592 1.48-3.087 2.292-4.105 2.295zm9.77-.02c-1.012 0-2.514-.808-4.11-2.28.686-.72 1.37-1.537 2.02-2.442 1.107-.117 2.154-.298 3.113-.538.112.49.195.964.254 1.42.23 1.868-.054 3.32-.714 3.707a1.16 1.16 0 0 1-.563.132z" />
              </svg>
            )}
            {example.id === 'vue' && (
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M24,1.61H14.06L12,5.16,9.94,1.61H0L12,22.39ZM12,14.08,5.16,2.23H9.59L12,6.41l2.41-4.18h4.43Z" />
              </svg>
            )}
            {example.label}
          </button>
        ))
      }
    </div>

    {
      QUICK_START_EXAMPLES.map((example, index) => (
        <div
          class={index === 0 ? 'quickstart-panel active' : 'quickstart-panel'}
          data-quickstart-panel={example.id}
        >
          <div class="code-header">
            <span class="code-title">{example.fileName}</span>
            <button class="code-copy" data-copy-quickstart={example.id} type="button">Copy</button>
          </div>
          <div class="code-content">
            <pre class={`language-${example.language}`}><code class={`language-${example.language}`}>{example.code}</code></pre>
          </div>
        </div>
      ))
    }
  </div>
</section>
