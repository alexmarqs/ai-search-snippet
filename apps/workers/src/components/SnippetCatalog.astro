---
import { SNIPPETS } from '../data/snippets.ts';
import ComponentCard from './ComponentCard.astro';

const [searchBar, searchModal, chatBubble, chatPage] = SNIPPETS;
---

<section class="section" id="configurator">
  <div class="component-grid">
    <ComponentCard
      snippetId={searchBar.id}
      title={searchBar.title}
      description={searchBar.description}
    >
      <svg viewBox="0 0 180 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="4" y="4" width="172" height="112" rx="4" stroke-width="1" style="fill: var(--stone-100); stroke: var(--stone-200)" />
        <rect x="12" y="12" width="80" height="6" rx="2" style="fill: var(--stone-200)" />
        <rect x="12" y="22" width="120" height="4" rx="1" style="fill: var(--stone-200)" />
        <rect x="12" y="32" width="156" height="76" rx="6" stroke-width="1.5" style="fill: var(--stone-50); stroke: var(--stone-300)" />
        <circle cx="28" cy="46" r="6" stroke-width="1.5" fill="none" style="stroke: var(--stone-400)" />
        <path d="M32 50L35 53" stroke-width="1.5" stroke-linecap="round" style="stroke: var(--stone-400)" />
        <rect x="42" y="43" width="60" height="6" rx="2" style="fill: var(--stone-300)" />
        <rect x="126" y="38" width="36" height="18" rx="4" fill="#F6821F" />
        <line x1="20" y1="62" x2="160" y2="62" stroke-width="1" style="stroke: var(--stone-200)" />
        <rect x="20" y="70" width="100" height="5" rx="1" style="fill: var(--stone-300)" />
        <rect x="20" y="79" width="80" height="3" rx="1" style="fill: var(--stone-200)" />
        <rect x="20" y="90" width="90" height="5" rx="1" style="fill: var(--stone-300)" />
        <rect x="20" y="99" width="70" height="3" rx="1" style="fill: var(--stone-200)" />
      </svg>
    </ComponentCard>

    <ComponentCard
      snippetId={searchModal.id}
      title={searchModal.title}
      description={searchModal.description}
    >
      <svg viewBox="0 0 180 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="4" y="4" width="172" height="112" rx="4" stroke-width="1" style="fill: var(--stone-100); stroke: var(--stone-200)" />
        <rect x="12" y="12" width="60" height="5" rx="1" style="fill: var(--stone-200)" />
        <rect x="12" y="22" width="100" height="4" rx="1" style="fill: var(--stone-200)" />
        <rect x="12" y="30" width="80" height="4" rx="1" style="fill: var(--stone-200)" />
        <rect x="20" y="20" width="140" height="92" rx="8" stroke-width="1.5" style="fill: var(--stone-50); stroke: var(--stone-300)" />
        <circle cx="36" cy="36" r="5" stroke-width="1.5" fill="none" style="stroke: var(--stone-400)" />
        <path d="M40 40L42 42" stroke-width="1.5" stroke-linecap="round" style="stroke: var(--stone-400)" />
        <rect x="48" y="33" width="60" height="5" rx="1" style="fill: var(--stone-300)" />
        <rect x="130" y="30" width="22" height="12" rx="2" style="fill: var(--stone-200)" />
        <text x="141" y="39" font-size="7" text-anchor="middle" font-family="system-ui" style="fill: var(--stone-500)">esc</text>
        <line x1="28" y1="50" x2="152" y2="50" stroke-width="1" style="stroke: var(--stone-200)" />
        <rect x="28" y="58" width="100" height="5" rx="1" style="fill: var(--stone-300)" />
        <rect x="28" y="67" width="80" height="3" rx="1" style="fill: var(--stone-200)" />
        <rect x="28" y="78" width="90" height="5" rx="1" style="fill: var(--stone-300)" />
        <rect x="28" y="87" width="70" height="3" rx="1" style="fill: var(--stone-200)" />
        <rect x="28" y="98" width="85" height="5" rx="1" style="fill: var(--stone-300)" />
      </svg>
    </ComponentCard>

    <ComponentCard
      snippetId={chatBubble.id}
      title={chatBubble.title}
      description={chatBubble.description}
    >
      <svg viewBox="0 0 180 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="4" y="4" width="172" height="112" rx="4" stroke-width="1" style="fill: var(--stone-100); stroke: var(--stone-200)" />
        <rect x="12" y="12" width="70" height="6" rx="2" style="fill: var(--stone-200)" />
        <rect x="12" y="24" width="120" height="4" rx="1" style="fill: var(--stone-200)" />
        <rect x="12" y="32" width="100" height="4" rx="1" style="fill: var(--stone-200)" />
        <rect x="12" y="40" width="110" height="4" rx="1" style="fill: var(--stone-200)" />
        <rect x="12" y="52" width="60" height="5" rx="1" style="fill: var(--stone-200)" />
        <rect x="12" y="62" width="90" height="4" rx="1" style="fill: var(--stone-200)" />
        <circle cx="148" cy="88" r="20" fill="#F6821F" />
        <path d="M140 83c0-1.1.9-2 2-2h12c1.1 0 2 .9 2 2v8c0 1.1-.9 2-2 2h-2l-3 3-3-3h-4c-1.1 0-2-.9-2-2v-8z" fill="#fff" />
      </svg>
    </ComponentCard>

    <ComponentCard
      snippetId={chatPage.id}
      title={chatPage.title}
      description={chatPage.description}
    >
      <svg viewBox="0 0 180 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="4" y="4" width="172" height="112" rx="4" stroke-width="1" style="fill: var(--stone-100); stroke: var(--stone-200)" />
        <rect x="56" y="5" width="119" height="110" style="fill: var(--stone-50)" />
        <rect x="5" y="5" width="50" height="110" style="fill: var(--stone-100)" />
        <path d="M55 5V115" stroke-width="1" style="stroke: var(--stone-200)" />
        <rect x="12" y="16" width="32" height="6" rx="2" style="fill: var(--stone-300)" />
        <rect x="12" y="28" width="28" height="4" rx="1" style="fill: var(--stone-200)" />
        <rect x="12" y="36" width="26" height="4" rx="1" style="fill: var(--stone-200)" />
        <rect x="12" y="44" width="30" height="4" rx="1" style="fill: var(--stone-200)" />
        <rect x="64" y="16" width="80" height="12" rx="4" style="fill: var(--stone-100)" />
        <rect x="84" y="34" width="86" height="12" rx="4" fill="#F6821F" opacity="0.15" />
        <rect x="64" y="52" width="70" height="12" rx="4" style="fill: var(--stone-100)" />
        <rect x="94" y="70" width="76" height="12" rx="4" fill="#F6821F" opacity="0.15" />
        <rect x="60" y="92" width="110" height="20" rx="4" stroke-width="1" style="fill: var(--stone-100); stroke: var(--stone-200)" />
        <rect x="68" y="99" width="60" height="5" rx="1" style="fill: var(--stone-300)" />
      </svg>
    </ComponentCard>
  </div>
</section>
