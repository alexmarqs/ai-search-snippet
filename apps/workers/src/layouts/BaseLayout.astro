---
import '../styles/global.css';

interface Props {
  description?: string;
  title?: string;
}

const {
  description = 'Open source Web Components for Cloudflare AI Search. Add AI-powered search and chat to your website in minutes.',
  title = 'AI Search Snippets - Embed AI Search on your website',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="bg-stone-50">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <script is:inline>
      (() => {
        try {
          const theme =
            localStorage.getItem('theme') ||
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          if (theme === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        } catch (_error) {}
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css"
    />
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"
      defer
    ></script>
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-markup.min.js"
      defer
    ></script>
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-css.min.js"
      defer
    ></script>
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-javascript.min.js"
      defer
    ></script>
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-jsx.min.js"
      defer
    ></script>
  </head>
  <body>
    <slot />
    <script src="../scripts/site.ts"></script>
    <script src="../scripts/unicorn-background.ts"></script>
  </body>
</html>
